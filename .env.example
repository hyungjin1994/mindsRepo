# Copy to .env.local and set your database + Supabase credentials.

# --- PostgreSQL (Prisma) ---
DATABASE_URL=postgresql://username:password@localhost:5432/minds?schema=public
DIRECT_URL=postgresql://username:password@localhost:5432/minds_shadow?schema=public

# --- Supabase (web + server) ---
# Public client (used in browser) — the anon key is safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://xyzcompany.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=public-anon-key
# Server-only service role key (DO NOT COMMIT to public repos)
SUPABASE_SERVICE_ROLE_KEY=service-role-key

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- SMTP (nodemailer) — optional, for magic-link / notification emails ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=smtp-user
SMTP_PASS=smtp-pass
SMTP_FROM="minds <no-reply@example.com>"

# --- Web Push (VAPID) ---
# Generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-vapid-key
VAPID_PRIVATE_KEY=your-private-vapid-key
VAPID_SUBJECT=mailto:admin@example.com

# --- Cron / notification endpoints shared secret ---
# When set, /api/cron/reminders, /api/reminders/send and /api/push/send require
# header  Authorization: Bearer <CRON_SECRET>.  Leave unset for local dev.
CRON_SECRET=
